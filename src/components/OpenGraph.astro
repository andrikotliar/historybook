---
import { metadataConfig } from '../configs/metadata';

type Props = {
  title: string;
  description: string;
};

const { title, description } = Astro.props;
---

<meta property="og:url" content={metadataConfig.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={metadataConfig.socialMediaImage} />

<meta name="twitter:site" content={metadataConfig.url} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={metadataConfig.socialMediaImage} />
<meta name="twitter:card" content="summary_large_image" />
