---
import { headerMenu } from '@/configs';
import Container from '@/components/container/Container.astro';
import Icon from '@/components/icon/Icon.astro';

const url = Astro.url;
---

<header class="header">
  <Container className="header-container">
    <a href="/" class="logo">
      <img src="/images/logo.svg" alt="HistoryBook" />
    </a>
    <button class="menu-button" id="menuButton" aria-label="Open menu">
      <Icon name="menu" />
    </button>
    <div class="navigation-wrapper" id="navigationWrapper">
      <nav class="navigation">
        {
          headerMenu.map((item) => (
            <a
              href={item.link}
              class:list={[
                'navigation-link',
                { 'navigation-link-active': url.pathname.includes(item.link) },
              ]}
            >
              {item.title}
            </a>
          ))
        }
      </nav>
    </div>
  </Container>
</header>

<script>
  const menuButton = document.getElementById('menuButton');
  const navigationWrapper = document.getElementById('navigationWrapper');

  const isMenuAvailable = menuButton && navigationWrapper;

  const VISIBLE_CLASS_NAME = 'navigation-wrapper-visible';

  const handleOpenMenu = (
    navigationWrapper: HTMLElement,
    bodyOverflow = '',
  ) => {
    navigationWrapper.classList.toggle(VISIBLE_CLASS_NAME);
    document.body.style.overflow = bodyOverflow;
  };

  if (isMenuAvailable) {
    menuButton.addEventListener('click', () => {
      handleOpenMenu(navigationWrapper, 'hidden');
    });

    navigationWrapper.addEventListener('click', (event) => {
      const target = event.target as Element;
      if (target?.classList.contains(VISIBLE_CLASS_NAME)) {
        handleOpenMenu(navigationWrapper);
      }
    });
  }
</script>

<style is:global>
  .header {
    position: sticky;
    top: 0;
    background-color: var(--main-color);
    z-index: 100;
    height: var(--header-height);
  }
  .header-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }
  .logo {
    width: 150px;
    font-size: 0;
  }
  .navigation {
    position: relative;
    display: flex;
    justify-content: center;
    gap: 20px;
  }
  .navigation-link {
    position: relative;
    color: #fff;
    font-size: 15px;
  }
  .navigation-link::after {
    content: '';
    position: absolute;
    bottom: -5px;
    left: 0;
    width: 100%;
    height: 2px;
    background-color: #fff;
    transition: 0.3s;
    visibility: hidden;
    opacity: 0;
  }
  .navigation-link:hover::after,
  .navigation-link-active::after {
    visibility: visible;
    opacity: 0.8;
  }
  .menu-button {
    width: 40px;
    height: 40px;
    display: none;
    background: transparent;
    border: none;
    color: #fff;
    cursor: pointer;
    position: relative;
    z-index: 5;
  }
  @media (max-width: 950px) {
    .logo {
      width: 150px;
    }
    .navigation-link {
      font-size: 14px;
    }
  }
  @media (max-width: 850px) {
    .navigation-wrapper {
      position: fixed;
      top: var(--header-height);
      left: 0;
      width: 100%;
      height: calc(100% - var(--header-height));
      overflow: hidden;
      background-color: rgb(0 0 0 / 85%);
      visibility: hidden;
      opacity: 0;
      transition: 0.3s;
    }
    .navigation-wrapper-visible {
      visibility: visible;
      opacity: 1;
    }
    .navigation {
      position: absolute;
      top: 0;
      right: 0;
      height: 100%;
      color: #000;
      background-color: #fff;
      padding: 20px;
      flex-direction: column;
      justify-content: flex-start;
      gap: 15px;
      transition: 0.4s;
      transform: translateX(150%);
      z-index: 100;
    }
    .navigation-wrapper-visible .navigation {
      transform: translateX(0);
    }
    .navigation-link {
      font-size: 18px;
      color: #000;
    }
    .navigation-link-active {
      color: var(--main-color);
    }
    .navigation-link-active::after {
      background-color: var(--main-color);
    }
    .menu-button {
      display: block;
      width: 30px;
      height: 30px;
    }
  }
  @media print {
    .header {
      display: none;
    }
  }
</style>
