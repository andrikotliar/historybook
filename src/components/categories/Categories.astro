---
import type { PageId } from '@/common';
import { pagesMapper } from '@/configs';

type Props = {
  pageId: PageId;
  categoryKey?: string;
};

const url = Astro.url;
const { pageId, categoryKey } = Astro.props;

const rootLink = `/${pageId}/`;
---

{
  pagesMapper[pageId].categories && (
    <nav class="categories">
      <a href={rootLink} class:list={['link', { active: !categoryKey }]}>
        Всі
      </a>
      {pagesMapper[pageId].categories?.map((category) => (
        <a
          href={`/${pageId}/${category.key}/`}
          class:list={['link', { active: categoryKey === category.key }]}
        >
          {category.linkTitle}
        </a>
      ))}
    </nav>
  )
}

<style scoped>
  .categories {
    margin-bottom: 30px;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 10px;
  }

  .link {
    position: relative;
    color: var(--dark-gray);
    padding: 5px;
    padding: 5px 20px;
    border: 1px solid var(--light-gray);
    border-radius: 50px;
    flex-shrink: 0;
  }

  .link:hover,
  .active {
    color: #fff;
    background-color: var(--main-color);
    border-color: var(--main-color);
  }

  .active {
    cursor: default;
    pointer-events: none;
  }
</style>
