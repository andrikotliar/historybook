---
import Grid from '@/components/grid/Grid.astro';
import LinkMore from '@/components/section/LinkMore.astro';
import type { PageData } from '@/configs';
import { ArticlesService } from '@/services';

type Props = PageData;

const { id, emoji, shortTitle, title } = Astro.props;

const { articles } = await ArticlesService.findManyArticles(id, { limit: 8 });
---

<section class="section">
  <h2 class="title">
    <span>{emoji}</span>
    <span>{title}</span>
  </h2>
  <Grid articles={articles} pageId={id} />
  <LinkMore title={shortTitle} pageId={id} />
</section>

<style scoped>
  .section {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 30px;
  }
  .section:last-child {
    margin-bottom: 0;
  }
  .title {
    display: flex;
    gap: 5px;
    font-size: 35px;
  }
  @media (max-width: 700px) {
    .title {
      font-size: 28px;
    }
  }
  @media (max-width: 580px) {
    .title {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
