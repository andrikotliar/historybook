<header class="header">
  <div class="container header-container">
    <div class="header-main">
      <a href="/" class="header-logo">
        <img src="/images/logo.svg" alt="HistoryBook" />
      </a>
      <button class="header-menu-button" id="menuButton" aria-label="Open menu">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" fill="currentColor"><g><path d="M441.13 166.52h-372a15 15 0 1 1 0-30h372a15 15 0 0 1 0 30ZM441.13 279.72h-372a15 15 0 1 1 0-30h372a15 15 0 0 1 0 30ZM441.13 392.92h-372a15 15 0 1 1 0-30h372a15 15 0 0 1 0 30Z" ></path></g></svg>
      </button>
    </div>
    <div class="header-navigation-wrapper" id="navigationWrapper">
      <nav class="header-navigation">
        {% for route in navigation %}
          <a href="{{route.link}}" class="header-navigation-link{% if route.link in page.url %} header-navigation-link-active{% endif %}">
            {{route.title}}
          </a>
        {% endfor %}
      </nav>
    </div>
  </div>
</header>