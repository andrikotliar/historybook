<div class="footer">
  <div class="container footer-container">
    <div class="footer-main">
      <span class="footer-title">
        {{metadata.title}}
      </span>
      <span class="footer-years">
        {{metadata.startYear}} - {{metadata.currentYear}}
      </span>
    </div>
    <button class="footer-up-button" id="upButton">
      <div class="footer-up-button-arrow">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" xmlns="http://www.w3.org/2000/svg"><path d="M4 12h16M14 6l6 6-6 6"></path></svg>
      </div>
      <span>На гору</span>
    </button>
  </div>
</div>